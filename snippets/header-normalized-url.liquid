{%- liquid
  assign normalized_url = url | default: ''
  assign normalized_title = title | default: '' | strip | downcase | replace: '&amp;', '&'
  assign normalized_handle = handle | default: normalized_title | handleize

  case normalized_handle
    when 'shop', 'shop-all', 'all'
      assign normalized_url = '/collections/all'
    when 'best-seller', 'best-sellers'
      assign normalized_url = '/collections/best-seller'
    when 'new', 'new-arrival', 'new-arrivals'
      assign normalized_url = '/collections/new-arrival'
    when 'sale'
      assign normalized_url = '/collections/summer-glow-sale'
    when 'sales'
      assign normalized_url = '/collections/sales/Sale'
    when 'hot', 'summer-hot', 'summer'
      assign normalized_url = '/collections/island-glow-club'
    when 'floral-beauty', 'bloom-for-yourself'
      assign normalized_url = '/collections/bloom-for-yourself'
    when 'music-festival'
      assign normalized_url = '/collections/music-festival'
    when 'ersa-essence'
      assign normalized_url = '/collections/ersa-essence'
    when 'lny-2026'
      assign normalized_url = '/collections/lny-2026'
    when 'love-edit', 'valentine'
      assign normalized_url = '/collections/valentine'
    when 'renaissance', 'golden-glamour'
      assign normalized_url = '/collections/golden-glamour'
    when 'press-on-toenails'
      assign normalized_url = '/collections/press-on-toenails'
    when 'shop-by-shape', 'shape'
      assign normalized_url = '/collections/shape/Shape'
    when 'almond'
      assign normalized_url = '/collections/almond/Almond'
    when 'coffin'
      assign normalized_url = '/collections/coffin/Coffin'
    when 'oval'
      assign normalized_url = '/collections/oval/Oval'
    when 'squoval'
      assign normalized_url = '/collections/squoval'
    when 'square'
      assign normalized_url = '/collections/square'
    when 'shop-by-length', 'length'
      assign normalized_url = '/collections/length/Length'
    when 'long'
      assign normalized_url = '/collections/long/Long'
    when 'medium'
      assign normalized_url = '/collections/medium/Medium'
    when 'short'
      assign normalized_url = '/collections/short'
    when 'tools-accessories', 'tools-and-accessories'
      assign normalized_url = '/collections/tools-accessories/TOOLS-%26-ACCESSORIES'
    when 'bundle', 'bundles', 'bundles-save-up-to-40'
      assign normalized_url = '/collections/bundle/BUNDLES'
  endcase

  echo normalized_url
-%}
