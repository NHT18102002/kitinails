{{ 'custom-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  {% if section.settings.remove_image_background %}
  #shopify-section-{{ section.id }} .ersa-collection-grid__image-wrapper {
    background: transparent !important;
    border-radius: 0 !important;
  }
  #shopify-section-{{ section.id }} .ersa-collection-grid__card {
    border-radius: 0;
    overflow: visible;
  }
  #shopify-section-{{ section.id }} .ersa-collection-grid__card:hover {
    box-shadow: none;
    transform: none;
  }
  #shopify-section-{{ section.id }} .ersa-collection-grid__card:hover .ersa-collection-grid__image {
    transform: scale(1.08);
  }
  #shopify-section-{{ section.id }} .ersa-collection-grid__title {
    text-transform: none;
    font-weight: 400;
    font-size: 1.6rem;
    letter-spacing: 0;
  }
  {% endif %}
  #shopify-section-{{ section.id }} .ersa-collection-grid__image--contain {
    object-fit: contain !important;
  }
  {% if section.settings.section_bg_color != blank %}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.section_bg_color }};
  }
  {% endif %}
{%- endstyle -%}

<div
  class="ersa-collection-grid ersa-collection-grid--{{ section.settings.heading | handleize }} color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
>
  <div class="ersa-collection-grid__inner page-width">
    {%- if section.settings.heading != blank -%}
      <div class="ersa-collection-grid__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        <h2 class="ersa-collection-grid__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | escape }}
        </h2>
        {%- if section.settings.subheading != blank -%}
          <p class="ersa-collection-grid__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div
        class="ersa-collection-grid__grid{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        style="--ersa-collection-grid-columns: {{ section.settings.columns_desktop }};"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        {%- for block in section.blocks -%}
          {%- liquid
            assign card_collection = block.settings.collection
            assign card_title = block.settings.title | default: card_collection.title | default: ''
            assign card_href = card_collection.url
            if card_href == blank and card_title != blank
              assign card_handle = card_title | handleize
              assign card_href = routes.collections_url | append: '/' | append: card_handle
            endif
            if card_href == blank
              assign card_href = routes.all_products_collection_url
            endif
          -%}
          <div
            class="ersa-collection-grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            <a
              href="{{ card_href }}"
              class="ersa-collection-grid__card"
              {% if card_collection == blank %}aria-label="Collection placeholder"{% endif %}
            >
              <div class="ersa-collection-grid__image-wrapper">
                {%- if block.settings.image_filename != blank -%}
                  <img
                    src="{{ block.settings.image_filename | asset_url }}"
                    alt="{{ block.settings.title | escape }}"
                    class="ersa-collection-grid__image ersa-collection-grid__image--{{ section.settings.image_fit }}{% if section.settings.remove_image_background %} ersa-collection-grid__image--no-bg{% endif %}"
                    width="800"
                    height="800"
                    loading="lazy"
                  >
                {%- elsif block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      widths: '300, 450, 600, 800',
                      sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
                      class: 'ersa-collection-grid__image ersa-collection-grid__image--custom',
                      loading: 'lazy',
                      alt: block.settings.image.alt | default: card_collection.title | escape
                  }}
                {%- elsif card_collection != blank and card_collection.featured_image != blank -%}
                  {{
                    card_collection.featured_image
                    | image_url: width: 800
                    | image_tag:
                      widths: '300, 450, 600, 800',
                      sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw',
                      class: 'ersa-collection-grid__image ersa-collection-grid__image--collection',
                      loading: 'lazy',
                      alt: card_collection.title | escape
                  }}
                {%- else -%}
                  <div class="ersa-collection-grid__placeholder">
                    {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {%- endif -%}
              </div>
              <div class="ersa-collection-grid__info">
                <h3 class="ersa-collection-grid__title">
                  {%- if block.settings.title != blank -%}
                    {{ block.settings.title | escape }}
                  {%- elsif card_collection != blank -%}
                    {{ card_collection.title | escape }}
                  {%- else -%}
                    {{ 'onboarding.collection_title' | t }}
                  {%- endif -%}
                </h3>
                {%- if section.settings.show_product_count and card_collection != blank -%}
                  <span class="ersa-collection-grid__count">
                    {{ card_collection.all_products_count }} products
                  </span>
                {%- endif -%}
              </div>
            </a>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.show_view_all -%}
        <div class="ersa-collection-grid__view-all center{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
          <a href="{{ routes.collections_url }}" class="button button--secondary">
            {{ section.settings.view_all_label | default: 'View all collections' | escape }}
          </a>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection Grid",
  "tag": "section",
  "class": "section-ersa-collection-grid",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Curated for Your Style",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h3", "label": "Small" },
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore our handpicked collections"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "default": true,
      "label": "Show product count"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show 'View all' button"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "default": "View All Collections",
      "label": "'View all' button label"
    },
    {
      "type": "select",
      "id": "image_fit",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" }
      ],
      "default": "cover",
      "label": "Image fit"
    },
    {
      "type": "checkbox",
      "id": "remove_image_background",
      "default": false,
      "label": "Remove image background"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section background color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection",
      "limit": 8,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image",
          "info": "Overrides the collection's featured image."
        },
        {
          "type": "text",
          "id": "image_filename",
          "label": "Local Image Filename",
          "info": "E.g., 'image.webp'. Overrides the custom image above."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title",
          "info": "Overrides the collection title."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Grid",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ]
}
{% endschema %}

