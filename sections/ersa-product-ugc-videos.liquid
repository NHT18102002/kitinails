{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="ersa-product-ugc-videos color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding" data-ersa-product-ugc>
  <div class="ersa-product-ugc-videos__header page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="ersa-product-ugc-videos__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
    {%- endif -%}
  </div>

  <div class="ersa-product-ugc-videos__shell page-width">
    <button class="ersa-product-ugc-videos__arrow ersa-product-ugc-videos__arrow--prev" type="button" aria-label="Previous videos" data-ersa-product-ugc-prev>
      <svg aria-hidden="true" focusable="false" viewBox="0 0 10 18">
        <path d="M7.8 16.7.7 9.2A1 1 0 0 1 .4 8.5c0-.2.1-.4.2-.6L7.8.4a.9.9 0 0 1 1.3 0c.4.4.4.9 0 1.3L2.6 8.5l6.6 6.9a.9.9 0 0 1 0 1.3.9.9 0 0 1-1.4 0Z" fill="currentColor"/>
      </svg>
    </button>

    <div class="ersa-product-ugc-videos__track" tabindex="0" aria-label="{{ section.settings.heading | escape }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign poster_filename = block.settings.poster_filename | strip
          assign poster_url = ''
          if block.settings.poster != blank
            assign poster_url = block.settings.poster | image_url: width: 720
          elsif poster_filename != blank
            assign poster_url = poster_filename | asset_url
          endif
        -%}
        <article class="ersa-product-ugc-videos__item" {{ block.shopify_attributes }}>
          <div class="ersa-product-ugc-videos__media" aria-label="{{ block.settings.title | escape }}">
            {%- if block.settings.video_src != blank and poster_url != blank -%}
              <video
                class="ersa-product-ugc-videos__poster"
                autoplay
                loop
                muted
                playsinline
                preload="metadata"
                poster="{{ poster_url }}"
                aria-label="{{ block.settings.title | escape }}"
              >
                <source src="{{ block.settings.video_src | escape }}" type="video/mp4">
              </video>
            {%- elsif block.settings.poster != blank -%}
              {{
                block.settings.poster
                | image_url: width: 720
                | image_tag:
                  loading: 'lazy',
                  widths: '260, 360, 540, 720',
                  sizes: '(min-width: 990px) 234px, 58vw',
                  alt: block.settings.title,
                  class: 'ersa-product-ugc-videos__poster'
              }}
            {%- elsif poster_filename != blank -%}
              <img
                src="{{ poster_filename | asset_url }}"
                alt="{{ block.settings.title | escape }}"
                class="ersa-product-ugc-videos__poster"
                width="720"
                height="1280"
                loading="lazy"
              >
            {%- else -%}
              {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg ersa-product-ugc-videos__poster' }}
            {%- endif -%}
            <span class="ersa-product-ugc-videos__play" aria-hidden="true">
              <svg focusable="false" viewBox="0 0 24 24">
                <path d="M6 4.8c0-1.2 1.3-1.9 2.3-1.3l11.3 6.8c1 .6 1 2.1 0 2.7L8.3 19.8c-1 .6-2.3-.1-2.3-1.3V4.8Z" fill="currentColor"/>
              </svg>
            </span>
          </div>
        </article>
      {%- endfor -%}
    </div>

    <button class="ersa-product-ugc-videos__arrow ersa-product-ugc-videos__arrow--next" type="button" aria-label="Next videos" data-ersa-product-ugc-next>
      <svg aria-hidden="true" focusable="false" viewBox="0 0 10 18">
        <path d="m2.2 16.7 7.1-7.5c.2-.2.3-.4.3-.7s-.1-.5-.2-.6L2.2.4A.9.9 0 0 0 .9.4a.9.9 0 0 0 0 1.3l6.5 6.8-6.6 6.9a.9.9 0 0 0 0 1.3.9.9 0 0 0 1.4 0Z" fill="currentColor"/>
      </svg>
    </button>
  </div>
</section>

<style>
  .ersa-product-ugc-videos {
    background: #fff;
    overflow: hidden;
  }

  .ersa-product-ugc-videos__header {
    display: flex;
    justify-content: center;
    margin-bottom: 1.6rem;
    text-align: center;
  }

  .ersa-product-ugc-videos__heading {
    margin: 0;
    color: #111;
    font-family: 'Playfair Display', 'Iowan Old Style', Baskerville, 'Times New Roman', serif;
    font-size: 4rem;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.15;
  }

  .ersa-product-ugc-videos__shell {
    position: relative;
    display: grid;
    grid-template-columns: 3.6rem minmax(0, 108.7rem) 3.6rem;
    justify-content: center;
    align-items: center;
    column-gap: 0.8rem;
  }

  .ersa-product-ugc-videos__track {
    display: flex;
    gap: 0.6rem;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .ersa-product-ugc-videos__track::-webkit-scrollbar {
    display: none;
  }

  .ersa-product-ugc-videos__item {
    flex: 0 0 23.4rem;
    scroll-snap-align: start;
  }

  .ersa-product-ugc-videos__media {
    position: relative;
    display: block;
    aspect-ratio: 9 / 16;
    overflow: hidden;
    border-radius: 1.5rem;
    background: #f4f0ef;
  }

  .ersa-product-ugc-videos__poster {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ersa-product-ugc-videos__play {
    position: absolute;
    top: 50%;
    left: 50%;
    display: grid;
    width: 6.4rem;
    height: 6.4rem;
    place-items: center;
    border: 0.2rem solid #fff;
    border-radius: 50%;
    color: #fff;
    opacity: 0.68;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .ersa-product-ugc-videos__play svg {
    width: 2.4rem;
    height: 2.4rem;
    margin-left: 0.2rem;
  }

  .ersa-product-ugc-videos__arrow {
    display: inline-grid;
    width: 3.6rem;
    height: 3.6rem;
    min-width: 3.6rem;
    min-height: 3.6rem;
    place-items: center;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: #fff;
    color: #090a0b;
    box-shadow: none;
    cursor: pointer;
  }

  .ersa-product-ugc-videos__arrow svg {
    width: 1rem;
    height: 1.8rem;
  }

  @media screen and (max-width: 989px) {
    .ersa-product-ugc-videos__shell {
      grid-template-columns: 1fr;
      padding-right: 0;
    }

    .ersa-product-ugc-videos__arrow {
      display: none;
    }

    .ersa-product-ugc-videos__track {
      padding-right: 2rem;
    }

    .ersa-product-ugc-videos__item {
      flex-basis: 23rem;
    }
  }

  @media screen and (max-width: 749px) {
    .ersa-product-ugc-videos__header {
      margin-bottom: 2rem;
    }

    .ersa-product-ugc-videos__heading {
      font-size: 3.4rem;
      line-height: 1.12;
    }

    .ersa-product-ugc-videos__track {
      gap: 0.8rem;
      padding-left: 1.8rem;
    }

    .ersa-product-ugc-videos__item {
      flex-basis: 23.4rem;
    }

    .ersa-product-ugc-videos__play {
      width: 5.6rem;
      height: 5.6rem;
    }
  }
</style>

<script>
  (() => {
    const sections = document.querySelectorAll('[data-ersa-product-ugc]');

    sections.forEach((section) => {
      const track = section.querySelector('.ersa-product-ugc-videos__track');
      const previous = section.querySelector('[data-ersa-product-ugc-prev]');
      const next = section.querySelector('[data-ersa-product-ugc-next]');

      if (!track || !previous || !next || section.dataset.ersaProductUgcReady === 'true') return;

      section.dataset.ersaProductUgcReady = 'true';
      track.scrollLeft = 0;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        section.querySelectorAll('video').forEach((video) => {
          video.removeAttribute('autoplay');
          video.pause();
        });
      }

      const scrollByCard = (direction) => {
        const firstCard = track.querySelector('.ersa-product-ugc-videos__item');
        const gap = parseFloat(getComputedStyle(track).columnGap || getComputedStyle(track).gap || 0);
        const distance = firstCard ? firstCard.getBoundingClientRect().width + gap : 240;
        track.scrollBy({ left: direction * distance, behavior: 'smooth' });
      };

      previous.addEventListener('click', () => scrollByCard(-1));
      next.addEventListener('click', () => scrollByCard(1));
    });
  })();
</script>

{% schema %}
{
  "name": "Kiti product UGC videos",
  "tag": "section",
  "class": "section section-ersa-product-ugc-videos",
  "max_blocks": 12,
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Kiti Babes in Action"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ]
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Top padding", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Bottom padding", "default": 60 }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video poster",
      "settings": [
        { "type": "image_picker", "id": "poster", "label": "Poster image" },
        { "type": "text", "id": "poster_filename", "label": "Theme asset filename fallback" },
        { "type": "text", "id": "video_src", "label": "Public MP4 source" },
        { "type": "text", "id": "title", "label": "Accessible title", "default": "Kiti Nails customer video" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kiti product UGC videos",
      "blocks": [
        { "type": "video", "settings": { "poster_filename": "product-ugc-video-01.jpg", "title": "Kiti Nails customer video" } },
        { "type": "video", "settings": { "poster_filename": "product-ugc-video-02.jpg", "title": "Kiti Nails customer video" } },
        { "type": "video", "settings": { "poster_filename": "product-ugc-video-03.jpg", "title": "Kiti Nails customer video" } },
        { "type": "video", "settings": { "poster_filename": "product-ugc-video-04.jpg", "title": "Kiti Nails customer video" } },
        { "type": "video", "settings": { "poster_filename": "product-ugc-video-05.jpg", "title": "Kiti Nails customer video" } },
        { "type": "video", "settings": { "poster_filename": "product-ugc-video-06.jpg", "title": "Kiti Nails customer video" } }
      ]
    }
  ]
}
{% endschema %}
