{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="ersa-icon-row color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="ersa-icon-row__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="ersa-icon-row__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="ersa-icon-row__grid" style="--ersa-icon-row-columns: {{ section.settings.columns_desktop }};">
      {%- for block in section.blocks -%}
        <article class="ersa-icon-row__item" {{ block.shopify_attributes }}>
          <span class="ersa-icon-row__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'heart' -%}{{ 'icon-heart.svg' | inline_asset_content }}
              {%- when 'truck' -%}{{ 'icon-truck.svg' | inline_asset_content }}
              {%- when 'star' -%}{{ 'icon-star.svg' | inline_asset_content }}
              {%- when 'recycle' -%}{{ 'icon-recycle.svg' | inline_asset_content }}
              {%- else -%}{{ 'icon-checkmark.svg' | inline_asset_content }}
            {%- endcase -%}
          </span>
          {%- if block.settings.title != blank -%}
            <h3 class="ersa-icon-row__title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="ersa-icon-row__text rte">{{ block.settings.text }}</div>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ersa icon row",
  "tag": "section",
  "class": "section section-ersa-icon-row",
  "max_blocks": 6,
  "settings": [
    { "type": "inline_richtext", "id": "heading", "label": "Heading" },
    { "type": "select", "id": "heading_size", "label": "Heading size", "default": "h2", "options": [ { "value": "h2", "label": "Small" }, { "value": "h1", "label": "Medium" }, { "value": "h0", "label": "Large" } ] },
    { "type": "range", "id": "columns_desktop", "min": 2, "max": 4, "step": 1, "default": 4, "label": "Desktop columns" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding", "default": 36 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 36 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Icon item",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "check", "options": [ { "value": "check", "label": "Check" }, { "value": "heart", "label": "Heart" }, { "value": "truck", "label": "Truck" }, { "value": "star", "label": "Star" }, { "value": "recycle", "label": "Recycle" } ] },
        { "type": "inline_richtext", "id": "title", "label": "Title", "default": "Handmade" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Salon-inspired press-on nails made for everyday wear.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ersa icon row",
      "blocks": [
        { "type": "item", "settings": { "icon": "heart", "title": "Handmade", "text": "<p>Detailed nail sets with a polished studio finish.</p>" } },
        { "type": "item", "settings": { "icon": "recycle", "title": "Reusable", "text": "<p>Designed to be worn, removed and enjoyed again.</p>" } },
        { "type": "item", "settings": { "icon": "star", "title": "Loved by shoppers", "text": "<p>Built around styles customers reach for most.</p>" } },
        { "type": "item", "settings": { "icon": "truck", "title": "Free Shipping", "text": "<p>Promote your current shipping threshold here.</p>" } }
      ]
    }
  ]
}
{% endschema %}