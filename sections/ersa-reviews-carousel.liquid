{{ 'custom-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="ersa-reviews-carousel color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
>
  <div class="ersa-reviews-carousel__inner page-width">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="ersa-reviews-carousel__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="ersa-reviews-carousel__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="ersa-reviews-carousel__heading {{ section.settings.heading_size }}">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}
        {%- if section.settings.rating_text != blank -%}
          <div class="ersa-reviews-carousel__rating-summary">
            <span class="ersa-reviews-carousel__stars-display" aria-hidden="true">★★★★★</span>
            <span class="ersa-reviews-carousel__rating-text">{{ section.settings.rating_text | escape }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="ersa-reviews-carousel__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ersa-reviews-carousel__track-wrapper">
        <div
          class="ersa-reviews-carousel__track{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
          {% endif %}
        >
          {%- for block in section.blocks -%}
            <figure
              class="ersa-reviews-carousel__card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {{ block.shopify_attributes }}
              {% if settings.animations_reveal_on_scroll %}
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
            >
              <div class="ersa-reviews-carousel__card-top">
                {%- if block.settings.show_stars -%}
                  <div class="ersa-reviews-carousel__card-stars" aria-label="{{ block.settings.rating | default: 5 }} out of 5 stars">
                    {%- assign star_count = block.settings.rating | default: 5 -%}
                    {%- for i in (1..5) -%}
                      {%- if i <= star_count -%}★{%- else -%}☆{%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- if block.settings.review_title != blank -%}
                  <h3 class="ersa-reviews-carousel__card-title">{{ block.settings.review_title | escape }}</h3>
                {%- endif -%}

                <blockquote class="ersa-reviews-carousel__card-quote">
                  {{ block.settings.review_text }}
                </blockquote>
              </div>

              <figcaption class="ersa-reviews-carousel__card-author">
                {%- if block.settings.author_image != blank -%}
                  {{
                    block.settings.author_image
                    | image_url: width: 120
                    | image_tag:
                      widths: '60, 120',
                      sizes: '48px',
                      class: 'ersa-reviews-carousel__avatar',
                      loading: 'lazy',
                      alt: block.settings.author_name | escape
                  }}
                {%- else -%}
                  <span class="ersa-reviews-carousel__avatar-placeholder" aria-hidden="true">
                    {{ block.settings.author_name | slice: 0 | upcase | default: '?' }}
                  </span>
                {%- endif -%}
                <div class="ersa-reviews-carousel__author-info">
                  <span class="ersa-reviews-carousel__author-name">{{ block.settings.author_name | escape }}</span>
                  {%- if block.settings.verified -%}
                    <span class="ersa-reviews-carousel__verified">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                      Verified Buyer
                    </span>
                  {%- endif -%}
                </div>
              </figcaption>
            </figure>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Reviews Carousel",
  "tag": "section",
  "class": "section-ersa-reviews-carousel",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "default": "CUSTOMER REVIEWS",
      "label": "Eyebrow text"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Loved by Thousands",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h3", "label": "Small" },
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "rating_text",
      "default": "4.9 from 5000+ Reviews",
      "label": "Rating summary text"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "See what our customers are saying"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "limit": 12,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_stars",
          "default": true,
          "label": "Show star rating"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Star rating"
        },
        {
          "type": "text",
          "id": "review_title",
          "label": "Review title",
          "default": "Love these nails!"
        },
        {
          "type": "richtext",
          "id": "review_text",
          "label": "Review text",
          "default": "<p>These are absolutely gorgeous! They fit perfectly and lasted over two weeks. I've received so many compliments. Will definitely be ordering more sets.</p>"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Happy Customer"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author photo"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "default": true,
          "label": "Show verified badge"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews Carousel",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "review_title": "Absolutely stunning!",
            "review_text": "<p>I get compliments everywhere I go. The quality is amazing and they last so long. Best press-on nails I've ever tried!</p>",
            "author_name": "Sarah M."
          }
        },
        {
          "type": "review",
          "settings": {
            "review_title": "Perfect fit every time",
            "review_text": "<p>The sizing guide was super helpful and each set fits like they were custom made. Love the variety of designs available.</p>",
            "author_name": "Jessica L."
          }
        },
        {
          "type": "review",
          "settings": {
            "review_title": "So easy to apply!",
            "review_text": "<p>I was nervous about trying press-ons but these were so simple. They look like I just left the salon. Already ordered my next set!</p>",
            "author_name": "Emily K."
          }
        },
        {
          "type": "review",
          "settings": {
            "review_title": "Worth every penny",
            "review_text": "<p>These nails are beautiful and high quality. They lasted 3 weeks with no lifting. So much better than going to the nail salon!</p>",
            "author_name": "Maria T."
          }
        }
      ]
    }
  ]
}
{% endschema %}
